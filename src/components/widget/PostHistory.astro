---
import { Icon } from "astro-icon/components";

interface Props {
  filePath: string;
}

const { filePath } = Astro.props;

// 读取 Git 历史文件
let gitHistory = {};
try {
  const historyFile = await import("../../json/git-history.json", {
    assert: { type: "json" },
  });
  gitHistory = historyFile.default;
} catch (error) {
  console.error("Failed to load git history:", error);
}

// 获取当前文件的修订历史
const fileHistory = gitHistory[filePath] || [];

// 格式化日期
function formatDate(dateString) {
  const date = new Date(dateString);
  return date.toLocaleDateString("zh-CN", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
  });
}

// 简化提交信息
function simplifyMessage(message) {
  // 移除常见的提交前缀
  const prefixes = ["feat:", "fix:", "style:", "docs:", "refactor:", "test:", "chore:", "perf:"];
  let simplified = message;
  prefixes.forEach((prefix) => {
    if (simplified.startsWith(prefix)) {
      simplified = simplified.substring(prefix.length).trim();
    }
  });
  return simplified;
}

const hasMultipleCommits = fileHistory.length > 1;
---

{fileHistory.length > 0 && (
  <div class="card-base p-4 mt-6 mb-4">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-bold text-lg flex items-center gap-2">
        <Icon name="material-symbols:history-rounded" class="text-[1.25rem]"></Icon>
        文章修订记录
      </h3>
      <span class="text-sm text-50">{fileHistory.length} 次修订</span>
    </div>

    <div class="space-y-3">
      {/* 最新一条始终显示 */}
      {fileHistory.slice(0, 1).map((commit, index) => (
        <div class="flex items-start gap-3 p-3 rounded-lg transition bg-[var(--btn-plain-bg-hover)]">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-[var(--primary)]/10 flex items-center justify-center">
            <Icon name="material-symbols:commit" class="text-[var(--primary)] text-[1rem]"></Icon>
          </div>

          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="font-medium text-sm text-90">{commit.author}</span>
              <span class="text-xs text-30">·</span>
              <span class="text-xs text-50">{formatDate(commit.date)}</span>
            </div>
            <p class="text-sm text-75 line-clamp-2">{simplifyMessage(commit.message)}</p>
            <a
              href={`https://github.com/wwwaaa123122/fuwari/commit/${commit.hash}`}
              target="_blank"
              rel="noopener"
              class="text-xs text-[var(--primary)] hover:underline mt-1 inline-flex items-center gap-1"
            >
              <Icon name="material-symbols:link" class="text-[0.875rem]"></Icon>
              查看提交
            </a>
          </div>

          <span class="flex-shrink-0 px-2 py-1 text-xs font-medium bg-[var(--primary)]/10 text-[var(--primary)] rounded-full">
            最新
          </span>
        </div>
      ))}

      {/* 历史记录，默认隐藏 */}
      {hasMultipleCommits && (
        <div id="history-collapsible" class="hidden space-y-3">
          {fileHistory.slice(1).map((commit, index) => (
            <div class="flex items-start gap-3 p-3 rounded-lg transition bg-[var(--btn-regular-bg)]">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-[var(--primary)]/10 flex items-center justify-center">
                <Icon name="material-symbols:commit" class="text-[var(--primary)] text-[1rem]"></Icon>
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-medium text-sm text-90">{commit.author}</span>
                  <span class="text-xs text-30">·</span>
                  <span class="text-xs text-50">{formatDate(commit.date)}</span>
                </div>
                <p class="text-sm text-75 line-clamp-2">{simplifyMessage(commit.message)}</p>
                <a
                  href={`https://github.com/wwwaaa123122/fuwari/commit/${commit.hash}`}
                  target="_blank"
                  rel="noopener"
                  class="text-xs text-[var(--primary)] hover:underline mt-1 inline-flex items-center gap-1"
                >
                  <Icon name="material-symbols:link" class="text-[0.875rem]"></Icon>
                  查看提交
                </a>
              </div>
            </div>
          ))}
        </div>
      )}

      {/* 展开/收起按钮 */}
      {hasMultipleCommits && (
        <button
          id="history-toggle"
          class="w-full py-2 text-sm text-[var(--primary)] hover:bg-[var(--btn-regular-bg)] rounded-lg transition flex items-center justify-center gap-1"
        >
          <span id="toggle-text">展开历史记录</span>
          <Icon name="material-symbols:expand-more-rounded" id="toggle-icon" class="text-[1rem] transition-transform"></Icon>
        </button>
      )}
    </div>
  </div>
)}

<script>
  const toggleBtn = document.getElementById('history-toggle');
  const collapsible = document.getElementById('history-collapsible');
  const toggleText = document.getElementById('toggle-text');
  const toggleIcon = document.getElementById('toggle-icon');
  
  let expanded = false;

  toggleBtn?.addEventListener('click', () => {
    expanded = !expanded;
    
    if (expanded) {
      collapsible?.classList.remove('hidden');
      toggleText!.textContent = '收起历史记录';
      toggleIcon?.classList.add('rotate-180');
    } else {
      collapsible?.classList.add('hidden');
      toggleText!.textContent = '展开历史记录';
      toggleIcon?.classList.remove('rotate-180');
    }
  });
</script>
