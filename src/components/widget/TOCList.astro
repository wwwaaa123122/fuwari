---
import type { MarkdownHeading } from "astro";

interface TocItem extends MarkdownHeading {
	children: TocItem[];
}

interface Props {
	items: TocItem[];
}

const { items } = Astro.props;
---

<ol id="toc" class="space-y-1">
	{items.map((item) => (
		<li>
			<a href={`#${item.slug}`} class="px-2 flex gap-2 relative transition w-full min-h-9 rounded-xl hover:bg-[var(--toc-btn-hover)] active:bg-[var(--toc-btn-active)] py-2">
				<div class="transition w-5 h-5 shrink-0 rounded-lg text-xs flex items-center justify-center font-bold bg-[var(--toc-badge-bg)] text-[var(--btn-content)]">
					{item.depth === 2 && <span>{items.indexOf(item) + 1}</span>}
					{item.depth === 3 && <div class="transition w-2 h-2 rounded-[0.1875rem] bg-[var(--toc-badge-bg)]"></div>}
					{item.depth === 4 && <div class="transition w-1.5 h-1.5 rounded-sm bg-black/5 dark:bg-white/10"></div>}
				</div>
				<div class:list={["transition min-w-0 flex-1 break-words", { "text-50 text-sm": item.depth <= 3, "text-30 text-xs": item.depth >= 4 }]}>
					{item.text}
				</div>
			</a>
			{item.children.length > 0 && (
				<ol class:list={["space-y-1", { "ml-4": item.depth >= 2, "ml-8": item.depth >= 3 }]}>
					{item.children.map((child) => (
						<li>
							<a href={`#${child.slug}`} class="px-2 flex gap-2 relative transition w-full min-h-9 rounded-xl hover:bg-[var(--toc-btn-hover)] active:bg-[var(--toc-btn-active)] py-2">
								<div class="transition w-2 h-2 rounded-[0.1875rem] bg-[var(--toc-badge-bg)]"></div>
								<div class="transition text-sm min-w-0 flex-1 break-words text-50">
									{child.text}
								</div>
							</a>
							{child.children.length > 0 && (
								<ol class="ml-4 space-y-1">
									{child.children.map((grandchild) => (
										<li>
											<a href={`#${grandchild.slug}`} class="px-2 flex gap-2 relative transition w-full min-h-9 rounded-xl hover:bg-[var(--toc-btn-hover)] active:bg-[var(--toc-btn-active)] py-2">
												<div class="transition w-1.5 h-1.5 rounded-sm bg-black/5 dark:bg-white/10"></div>
												<div class="transition text-30 min-w-0 flex-1 break-words">
													{grandchild.text}
												</div>
											</a>
										</li>
									))}
								</ol>
							)}
						</li>
					))}
				</ol>
			)}
		</li>
	))}
</ol>
